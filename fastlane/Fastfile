default_platform(:ios)

platform :ios do
  desc "Deploy to TestFlight"
  lane :deploy do
    api_key = app_store_connect_api_key(
      key_id: "PJR7U4Y6TQ",
      issuer_id: "1aa9f658-125d-4760-b583-23736ce6fbde",
      key_filepath: File.expand_path("../private_keys/AuthKey_PJR7U4Y6TQ.p8")
    )

    # Read and increment build number
    project_yml = File.read("../project.yml")
    current_build = project_yml.match(/CURRENT_PROJECT_VERSION: "(\d+)"/)[1].to_i
    new_build = current_build + 1
    updated = project_yml.gsub(
      "CURRENT_PROJECT_VERSION: \"#{current_build}\"",
      "CURRENT_PROJECT_VERSION: \"#{new_build}\""
    )
    File.write("../project.yml", updated)
    UI.message("Build #{new_build}")

    # Regenerate Xcode project
    sh("cd .. && xcodegen generate --quiet")

    # Get signing certificate and profile
    get_certificates(api_key: api_key)
    get_provisioning_profile(
      api_key: api_key,
      app_identifier: "com.shloimyfuchs.CalorieTracker",
      force: false
    )

    profile_path = lane_context[SharedValues::SIGH_PROFILE_PATH]
    profile_uuid = lane_context[SharedValues::SIGH_UDID]

    # Build and archive
    build_app(
      scheme: "CalorieTracker",
      export_method: "app-store",
      output_directory: "./build",
      clean: true,
      export_options: {
        signingStyle: "manual",
        signingCertificate: "Apple Distribution",
        provisioningProfiles: {
          "com.shloimyfuchs.CalorieTracker" => profile_uuid
        }
      },
      xcargs: "DEVELOPMENT_TEAM=77QM6XDVU9 PROVISIONING_PROFILE_SPECIFIER='#{profile_uuid}' CODE_SIGN_IDENTITY='Apple Distribution'"
    )

    # Upload to TestFlight
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )

    UI.success("Build #{new_build} uploaded to TestFlight!")
  end
end
